        </sql>
    </changeSet>

    <!--
        NOTE: on the dev DB this ended up byte-for-byte identical to
        idx_form058_incoming_created_fast (same columns, same predicate) —
        a pre-existing duplicate from before Liquibase tracked this table.
        Captured here as-is to match current reality; consider dropping one
        of the two in a follow-up cleanup once confirmed safe.
    -->
    <changeSet id="20260717-1000-04-add-idx-form058-incoming-table" author="uzinfocom">
