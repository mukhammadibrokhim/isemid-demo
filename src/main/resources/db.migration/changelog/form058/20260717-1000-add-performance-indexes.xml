<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
            http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
        Bosqich 1 — dev DB'da allaqachon mavjud, lekin hech qanday Liquibase
        changelog'da qayd etilmagan 5 ta indeks (ehtimol vaqtida qo'lda yoki
        boshqa vosita orqali qo'shilgan). Har biri o'z indexExists
        preCondition'i bilan himoyalangan — shu sababli bu changeset'lar
        yangi (bo'sh) DB'da haqiqatan yaratadi, dev DB'da esa xavfsiz
        o'tkazib yuboriladi (MARK_RAN). Bu — Liquibase orqali qurilgan har
        qanday YANGI muhitning ishlash tezligi dev DB bilan bir xil
        bo'lishini kafolatlaydi.
    -->
    <changeSet id="20260717-1000-01-add-idx-form058-outgoing-created-fast" author="uzinfocom">
        <preConditions onFail="MARK_RAN" onError="HALT">
            <not>
                <indexExists indexName="idx_form058_outgoing_created_fast"/>
            </not>
        </preConditions>
        <sql dbms="postgresql">
            CREATE INDEX idx_form058_outgoing_created_fast
                ON form058 (sender_organization_id, created_at DESC, id DESC)
                WHERE deleted = false;
        </sql>
    </changeSet>

    <changeSet id="20260717-1000-02-add-idx-form058-incoming-created-fast" author="uzinfocom">
        <preConditions onFail="MARK_RAN" onError="HALT">
