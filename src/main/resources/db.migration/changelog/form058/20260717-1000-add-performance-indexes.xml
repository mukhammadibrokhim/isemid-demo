    <!--
        Bosqich 2 — yangi indekslar. `source` va `has_linked_cards` bo'yicha
        filtrlash (boshqa hech qanday tashkilot/sana cheklovisiz, masalan
        Respublika darajasidagi foydalanuvchi uchun) hech qanday mos indeks
        bo'lmagani sababli to'liq jadval skaneriga olib kelardi (haqiqiy dev
        DB'da tasdiqlandi: source='DMED' — 124ms, to'liq parallel seq scan;
        has_linked_cards=true — 53ms). Ikkalasi ham shu indekslar bilan
        1ms dan kam bo'ldi.
    -->
    <changeSet id="20260717-1000-06-add-idx-form058-source-created-fast" author="uzinfocom">
        <preConditions onFail="MARK_RAN" onError="HALT">
            <not>
                <indexExists indexName="idx_form058_source_created_fast"/>
