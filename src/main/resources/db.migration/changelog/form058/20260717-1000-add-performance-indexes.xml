    </changeSet>

    <!--
        Bosqich 3 — diffni tekshirish jarayonida (bo'sh DB'ga to'liq
        changelog to'plamini qo'llab, natijani haqiqiy dev DB bilan
        solishtirib) topilgan yana 6 ta indeks: ular ham hech qachon
        Liquibase orqali emas, balki Form058 entity'sining @Index
        e'lonlariga mos qilib ddl-auto=update orqali yaratilgan edi.
        Ayniqsa idx_form058_created_at va ikkita composite
        (deleted,sender/receiver,created_at) indekssiz — "ALL scope +
        faqat sana oralig'i, boshqa hech qanday filtrsiz" so'rov (Bosqich
        1dagi asosiy xato bilan bir xil sabab) yangi (Liquibase orqali
        qurilgan) muhitda hamon sekin bo'lib qolardi.
    -->
    <changeSet id="20260717-1000-08-add-idx-form058-status" author="uzinfocom">
        <preConditions onFail="MARK_RAN" onError="HALT">
            <not>
                <indexExists indexName="idx_form058_status"/>
            </not>
        </preConditions>
        <sql dbms="postgresql">CREATE INDEX idx_form058_status ON form058 (status);</sql>
    </changeSet>

