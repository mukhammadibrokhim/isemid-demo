<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
            http://www.liquibase.org/xml/ns/dbchangelog
            https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet
            id="20260514-1819-rename-recommended-activity-to-recommended-activities-act224-detail"
            author="muhammadibrohim">

        <preConditions onFail="MARK_RAN">
            <and>
                <columnExists
                        tableName="act224_detail"
                        columnName="recommended_activity"/>

                <not>
                    <columnExists
                            tableName="act224_detail"
                            columnName="recommended_activities"/>
                </not>
            </and>
        </preConditions>

        <renameColumn
                tableName="act224_detail"
                oldColumnName="recommended_activity"
                newColumnName="recommended_activities"
                columnDataType="varchar(255)"/>
    </changeSet>

</databaseChangeLog>