<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
            http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
        Migrates the legacy act153/154/155/156/223/224 structured data model
        onto the "act" table introduced in 20260716-1200/20260717-1400: "act"
        becomes the JOINED-inheritance root (institution + LIS transmission
        tracking added here), one child table per subtype holds its own
        structured fields (PK is also an FK to act.id, per JOINED strategy),
        and each subtype's "detail" child table is a normal
        UuidAuditableEntity-shaped table (its own id/version/audit/uuid
        columns) with a FK back to its parent subtype row.
    -->

    <changeSet id="20260722-1600-01-extend-act-institution-and-lis" author="uzinfocom">
        <preConditions onFail="MARK_RAN" onError="HALT">
            <not>
                <columnExists tableName="act" columnName="lis_status"/>
            </not>
        </preConditions>
        <addColumn tableName="act">
            <column name="subject_type" type="VARCHAR(50)"/>
            <column name="tin" type="INTEGER"/>
            <column name="institution_name" type="TEXT"/>
            <column name="institution_address" type="TEXT"/>
            <column name="institution_legal_address" type="TEXT"/>
            <column name="lis_status" type="VARCHAR(32)" defaultValue="NOT_SENT">
                <constraints nullable="false"/>
            </column>
            <column name="lis_attempt" type="INTEGER" defaultValueNumeric="0"/>
            <column name="lis_sent_date" type="TIMESTAMP WITHOUT TIME ZONE"/>
            <column name="lis_act_id" type="BIGINT"/>
            <column name="lis_response" type="jsonb"/>
        </addColumn>
    </changeSet>

