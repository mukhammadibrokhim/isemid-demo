<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
            http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
        act_act_status_check is a stale, untracked check constraint present
        on some environments' act table (not created by any changeset in
        this changelog) that still only allows the old three-value
        NEW/SENT/RECEIVED status set. ActStatus is now five values
        (NEW/IN_PROGRESS/READY/SENT/COMPLETED, see ActStatus.java) and, like
        every other status column in this codebase, is validated at the
        Java/@Enumerated(EnumType.STRING) layer only - no other status
        column has a DB-level check constraint. Dropped rather than
        redefined to match that convention and avoid the constraint
        drifting out of sync again on the next status change.
    -->
    <changeSet id="20260723-1200-01-drop-stale-act-status-check" author="uzinfocom">
        <sql>ALTER TABLE act DROP CONSTRAINT IF EXISTS act_act_status_check;</sql>
    </changeSet>

</databaseChangeLog>
