<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
            http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
        Act delete is now soft delete, mirroring form058
        (form058/20260622-1200-refactor-form058-relations.xml): the row stays,
        marked via these columns, instead of DELETE FROM act. See
        ActDeleteInfo/Act.softDelete and ActCommandService.delete.
    -->
    <changeSet id="20260724-1100-01-add-act-soft-delete-columns" author="uzinfocom">
        <preConditions onFail="MARK_RAN" onError="HALT">
            <not>
                <columnExists tableName="act" columnName="deleted"/>
            </not>
        </preConditions>
        <addColumn tableName="act">
            <column name="deleted" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="deleted_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="deleted_by_id" type="BIGINT"/>
            <column name="delete_reason" type="VARCHAR(1000)"/>
        </addColumn>
    </changeSet>

    <changeSet id="20260724-1100-02-index-act-deleted" author="uzinfocom">
        <preConditions onFail="MARK_RAN" onError="HALT">
            <not>
                <indexExists tableName="act" indexName="idx_act_deleted"/>
            </not>
        </preConditions>
        <createIndex indexName="idx_act_deleted" tableName="act" using="btree">
            <column name="deleted"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
