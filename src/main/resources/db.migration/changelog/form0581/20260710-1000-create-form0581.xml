<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
            http://www.liquibase.org/xml/ns/dbchangelog
            https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260710-1000-01-create-form0581" author="codex">
        <createTable tableName="form058_1">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" primaryKeyName="pk_form0581" nullable="false"/>
            </column>
            <column name="version" type="BIGINT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="uuid" type="UUID">
                <constraints nullable="false" unique="true" uniqueConstraintName="uk_form0581_uuid"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="created_by_id" type="BIGINT"/>
            <column name="updated_by_id" type="BIGINT"/>
            <column name="created_org_uuid" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="updated_org_uuid" type="UUID"/>

            <column name="mkb10_code" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="mkb10_name" type="VARCHAR(512)">
                <constraints nullable="false"/>
            </column>
            <column name="injury_localization" type="VARCHAR(500)"/>
            <column name="final_mkb10_code" type="VARCHAR(20)"/>
            <column name="final_mkb10_name" type="VARCHAR(512)"/>

            <column name="status" type="VARCHAR(32)">
                <constraints nullable="false"/>
            </column>
            <column name="source" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>

            <column name="patient_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_form0581_patient" references="patient(id)"/>
            </column>
            <column name="sender_organization_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="receiver_organization_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>

            <column name="injury_date_time" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="dpu_visit_date_time" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="injury_region_code" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="injury_district_code" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="injury_address" type="VARCHAR(1000)"/>

            <column name="animal_category_code" type="VARCHAR(64)"/>
            <column name="animal_color" type="VARCHAR(255)"/>
            <column name="animal_type" type="VARCHAR(255)"/>
            <column name="animal_breed" type="VARCHAR(255)"/>

            <column name="owner_last_name" type="VARCHAR(255)"/>
            <column name="owner_first_name" type="VARCHAR(255)"/>
            <column name="owner_middle_name" type="VARCHAR(255)"/>
            <column name="owner_region_code" type="VARCHAR(64)"/>
            <column name="owner_district_code" type="VARCHAR(64)"/>
            <column name="owner_neighborhood_code" type="VARCHAR(64)"/>
            <column name="owner_street" type="VARCHAR(255)"/>
            <column name="owner_house_number" type="VARCHAR(32)"/>
            <column name="owner_apartment_number" type="VARCHAR(32)"/>

            <column name="other_people_injured" type="BOOLEAN"/>

            <column name="hospitalized_at" type="TIMESTAMP"/>
            <column name="hospital_organization_id" type="BIGINT"/>

            <column name="antirabic_assistance_info" type="VARCHAR(2000)"/>
            <column name="notifier_full_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="receiver_full_name" type="VARCHAR(255)"/>
            <column name="message_sent_at" type="TIMESTAMP"/>

            <column name="cancel_reason" type="VARCHAR(1000)"/>
            <column name="canceled_by_id" type="BIGINT"/>
            <column name="canceled_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="not_approved_reason" type="VARCHAR(1000)"/>

            <column name="approved_by_id" type="BIGINT"/>
            <column name="approved_organization_id" type="BIGINT"/>
            <column name="approved_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="approved_full_name" type="VARCHAR(255)"/>
            <column name="approved_org_uuid" type="UUID"/>

            <column name="deleted" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="deleted_at" type="TIMESTAMP WITH TIME ZONE"/>
            <column name="deleted_by_id" type="BIGINT"/>
            <column name="delete_reason" type="VARCHAR(1000)"/>
        </createTable>

        <createIndex tableName="form058_1" indexName="idx_form0581_status">
            <column name="status"/>
        </createIndex>
        <createIndex tableName="form058_1" indexName="idx_form0581_patient_id">
            <column name="patient_id"/>
        </createIndex>
        <createIndex tableName="form058_1" indexName="idx_form0581_sender_org_id">
            <column name="sender_organization_id"/>
        </createIndex>
        <createIndex tableName="form058_1" indexName="idx_form0581_receiver_org_id">
            <column name="receiver_organization_id"/>
        </createIndex>
        <createIndex tableName="form058_1" indexName="idx_form0581_created_at">
            <column name="created_at"/>
        </createIndex>
        <createIndex tableName="form058_1" indexName="idx_form0581_mkb10_code">
            <column name="mkb10_code"/>
        </createIndex>
        <createIndex tableName="form058_1" indexName="idx_form0581_deleted">
            <column name="deleted"/>
        </createIndex>
        <createIndex tableName="form058_1" indexName="idx_form0581_deleted_sender_created">
            <column name="deleted"/>
            <column name="sender_organization_id"/>
            <column name="created_at"/>
        </createIndex>
        <createIndex tableName="form058_1" indexName="idx_form0581_deleted_receiver_created">
            <column name="deleted"/>
            <column name="receiver_organization_id"/>
            <column name="created_at"/>
        </createIndex>
    </changeSet>

    <changeSet id="20260710-1000-02-create-form0581-other-injured-person" author="codex">
        <createTable tableName="form058_1_other_injured_person">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" primaryKeyName="pk_form0581_other_injured_person" nullable="false"/>
            </column>
            <column name="version" type="BIGINT" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="uuid" type="UUID">
                <constraints nullable="false" unique="true" uniqueConstraintName="uk_form0581_other_injured_person_uuid"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE">
                <constraints nullable="false"/>
            </column>
            <column name="created_by_id" type="BIGINT"/>
            <column name="updated_by_id" type="BIGINT"/>

            <column name="form0581_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_form0581_other_injured_person_form0581"
                             references="form058_1(id)"/>
            </column>

            <column name="last_name" type="VARCHAR(255)"/>
            <column name="first_name" type="VARCHAR(255)"/>
            <column name="middle_name" type="VARCHAR(255)"/>

            <column name="region_code" type="VARCHAR(64)"/>
            <column name="district_code" type="VARCHAR(64)"/>
            <column name="neighborhood_code" type="VARCHAR(64)"/>
            <column name="street" type="VARCHAR(255)"/>
            <column name="house_number" type="VARCHAR(32)"/>
            <column name="apartment_number" type="VARCHAR(32)"/>
        </createTable>

        <createIndex tableName="form058_1_other_injured_person"
                     indexName="idx_form0581_other_injured_person_form0581_id">
            <column name="form0581_id"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
