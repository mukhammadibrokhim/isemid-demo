<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
            http://www.liquibase.org/xml/ns/dbchangelog
            https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- ========================================================= -->
    <!-- Add organization.tin column if it does not exist           -->
    <!-- ========================================================= -->
    <changeSet id="20260525-1110-01-add-tin-to-organization" author="muhammadibrohim">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="organization"/>
            <not>
                <columnExists tableName="organization" columnName="tin"/>
            </not>
        </preConditions>

        <addColumn tableName="organization">
            <column name="tin" type="VARCHAR(50)"/>
        </addColumn>
    </changeSet>

    <!-- ========================================================= -->
    <!-- Add organization.phone column if it does not exist         -->
    <!-- ========================================================= -->
    <changeSet id="20260525-1110-02-add-phone-to-organization" author="muhammadibrohim">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="organization"/>
            <not>
                <columnExists tableName="organization" columnName="phone"/>
            </not>
        </preConditions>

        <addColumn tableName="organization">
            <column name="phone" type="VARCHAR(50)"/>
        </addColumn>
    </changeSet>

    <!-- ========================================================= -->
    <!-- Create organization_service_types table if it does not     -->
    <!-- exist. This table is used for Organization.serviceTypes     -->
    <!-- @ElementCollection mapping.                                -->
    <!-- ========================================================= -->
    <changeSet id="20260525-1110-03-create-organization-service-types" author="muhammadibrohim">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="organization_service_types"/>
            </not>
        </preConditions>

        <createTable tableName="organization_service_types">
            <column name="organization_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>

            <column name="service_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <!-- ========================================================= -->
    <!-- Add organization_id column if the table already exists      -->
    <!-- but the column is missing.                                  -->
    <!-- ========================================================= -->
    <changeSet id="20260525-1110-04-add-organization-id-to-service-types" author="muhammadibrohim">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="organization_service_types"/>
            <not>
                <columnExists tableName="organization_service_types" columnName="organization_id"/>
            </not>
        </preConditions>

        <addColumn tableName="organization_service_types">
            <column name="organization_id" type="BIGINT"/>
        </addColumn>
    </changeSet>

    <!-- ========================================================= -->
    <!-- Add service_type column if the table already exists         -->
    <!-- but the column is missing.                                  -->
    <!-- ========================================================= -->
    <changeSet id="20260525-1110-05-add-service-type-to-organization-service-types" author="muhammadibrohim">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="organization_service_types"/>
            <not>
                <columnExists tableName="organization_service_types" columnName="service_type"/>
            </not>
        </preConditions>

        <addColumn tableName="organization_service_types">
            <column name="service_type" type="VARCHAR(50)"/>
        </addColumn>
    </changeSet>

    <!-- ========================================================= -->
    <!-- Add foreign key from organization_service_types to          -->
    <!-- organization if it does not exist.                          -->
    <!-- ========================================================= -->
    <changeSet id="20260525-1110-06-add-fk-organization-service-types" author="muhammadibrohim">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="organization"/>
            <tableExists tableName="organization_service_types"/>
            <columnExists tableName="organization" columnName="id"/>
            <columnExists tableName="organization_service_types" columnName="organization_id"/>
            <not>
                <foreignKeyConstraintExists foreignKeyName="fk_organization_service_types_organization"/>
            </not>
        </preConditions>

        <addForeignKeyConstraint
                baseTableName="organization_service_types"
                baseColumnNames="organization_id"
                referencedTableName="organization"
                referencedColumnNames="id"
                constraintName="fk_organization_service_types_organization"
                onDelete="CASCADE"/>
    </changeSet>

    <!-- ========================================================= -->
    <!-- Add index for faster loading of Organization.serviceTypes   -->
    <!-- by organization_id.                                         -->
    <!-- ========================================================= -->
    <changeSet id="20260525-1110-07-add-index-organization-service-types-org-id" author="muhammadibrohim">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="organization_service_types"/>
            <columnExists tableName="organization_service_types" columnName="organization_id"/>
            <not>
                <indexExists tableName="organization_service_types"
                             indexName="idx_organization_service_types_org_id"/>
            </not>
        </preConditions>

        <createIndex tableName="organization_service_types"
                     indexName="idx_organization_service_types_org_id">
            <column name="organization_id"/>
        </createIndex>
    </changeSet>

    <!-- ========================================================= -->
    <!-- Add index for filtering/searching organizations by          -->
    <!-- service_type when needed.                                   -->
    <!-- ========================================================= -->
    <changeSet id="20260525-1110-08-add-index-organization-service-types-service-type" author="muhammadibrohim">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="organization_service_types"/>
            <columnExists tableName="organization_service_types" columnName="service_type"/>
            <not>
                <indexExists tableName="organization_service_types"
                             indexName="idx_organization_service_types_service_type"/>
            </not>
        </preConditions>

        <createIndex tableName="organization_service_types"
                     indexName="idx_organization_service_types_service_type">
            <column name="service_type"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>